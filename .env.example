# Atlas Cloud API密钥（必需）
# 获取地址：https://www.atlascloud.ai?ref=JPM683（首充25%奖励）
ATLAS_API_KEY=your-api-key-here

# 自定义API基础地址（可选，默认：https://api.atlascloud.ai/v1）
# ATLAS_BASE_URL=https://api.atlascloud.ai/v1

# 默认模型标识（可选，默认：deepseek/deepseek-v3.2）
# DEEPSEEK_MODEL=deepseek/deepseek-v3.2

# 默认温度参数（可选，默认：0.7）
# DEEPSEEK_TEMPERATURE=0.7

# 默认最大输出token数（可选，默认：4096）
# DEEPSEEK_MAX_TOKENS=4096
